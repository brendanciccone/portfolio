# Web3Forms access key for the contact form — create one at https://web3forms.com
# for the inbox that should receive submissions.
#
# This is a publishable key (Web3Forms keys are designed to ship in client
# bundles). It is inlined into the static export at BUILD time, so it must be
# present in .env before running `pnpm build` / `pnpm run deploy`. Nothing
# needs to be set in the Cloudflare Pages dashboard for direct-upload deploys.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
